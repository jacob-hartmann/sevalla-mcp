## Sevalla MCP environment variables
##
## Copy this file to `.env` and fill in the values.
## NOTE: `.env` is gitignored (do not commit secrets).

# ─────────────────────────────────────────────────────────────────────────────
# Transport selection
# ─────────────────────────────────────────────────────────────────────────────

# Transport mode: "stdio" (default) or "http"
# MCP_TRANSPORT=stdio

# ─────────────────────────────────────────────────────────────────────────────
# Sevalla API credentials (required)
# ─────────────────────────────────────────────────────────────────────────────

# Get your API key from: https://app.sevalla.com → Settings → API Keys
SEVALLA_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Company ID (required for list operations)
# ─────────────────────────────────────────────────────────────────────────────

# Your Sevalla company UUID. Found in the Sevalla dashboard URL or API.
SEVALLA_COMPANY_ID=

# ─────────────────────────────────────────────────────────────────────────────
# HTTP mode settings (MCP_TRANSPORT=http)
# ─────────────────────────────────────────────────────────────────────────────

# Host to bind the HTTP server to
# MCP_SERVER_HOST=127.0.0.1

# Port to listen on
# MCP_SERVER_PORT=3000
